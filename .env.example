# Tunnel domain - wildcard DNS must point to this server
# e.g., *.tunnel.example.com → ALB
TUNNEL_DOMAIN=tunnel.example.com

# Admin console token for sish web admin
ADMIN_TOKEN=changeme-to-a-strong-secret

# Path to authorized SSH public keys directory
# Can be absolute or relative to project root
PUBKEYS_DIR=./data/pubkeys

# AWS settings (used by setup scripts)
AWS_REGION=ap-northeast-1
AWS_HOSTED_ZONE_ID=Z0123456789ABCDEFGHIJ

# ALB DNS name (e.g., my-alb-123456.ap-northeast-1.elb.amazonaws.com)
# Used by setup-dns.sh to create ALIAS records pointing to ALB
ALB_DNS_NAME=
# ALB hosted zone ID (fixed per region, see https://docs.aws.amazon.com/elasticloadbalancing/latest/application/load-balancer-troubleshooting.html)
ALB_HOSTED_ZONE_ID=
